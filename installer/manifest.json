{
  "agents": [
    {
      "id": "forge",
      "name": "Forge",
      "description": "Autonomous dev agent. Picks up GitHub issues, writes code, opens PRs.",
      "integrations": {
        "discord": "required",
        "github": "required",
        "claude": "required"
      }
    },
    {
      "id": "scouter",
      "name": "Scouter",
      "description": "Monitors sources and reports insights to Discord.",
      "integrations": {
        "discord": "required",
        "xurl": "optional"
      }
    },
    {
      "id": "alfred",
      "name": "Alfred",
      "description": "Personal assistant with Google Workspace integration.",
      "integrations": {
        "discord": "required",
        "gws": "required"
      }
    }
  ],
  "integrations": {
    "discord": {
      "label": "Discord",
      "per_agent_keys": ["DISCORD_{{AGENT}}_TOKEN", "DISCORD_{{AGENT}}_CHANNEL"],
      "shared_keys": ["DISCORD_GUILD"],
      "module": "discord.sh"
    },
    "github": {
      "label": "GitHub",
      "shared_keys": ["GH_TOKEN"],
      "module": "github.sh"
    },
    "claude": {
      "label": "Claude Code",
      "shared_keys": ["CLAUDE_CODE_OAUTH_TOKEN"],
      "module": "claude.sh"
    },
    "gws": {
      "label": "Google Workspace",
      "shared_keys": [],
      "module": "gws.sh",
      "note": "Credentials stored as file, not env var"
    },
    "xurl": {
      "label": "X/Twitter",
      "shared_keys": ["X_BEARER_TOKEN"],
      "optional_keys": ["X_CLIENT_ID", "X_CLIENT_SECRET"],
      "module": "xurl.sh"
    }
  }
}
