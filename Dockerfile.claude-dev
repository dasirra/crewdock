FROM debian:bookworm-slim

# Install Node.js 22, Python 3, Git
RUN apt-get update && apt-get install -y \
    curl git python3 python3-pip \
    openssh-client ca-certificates gnupg \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Python dependencies
WORKDIR /app
COPY claude-dev/requirements.txt .
RUN pip3 install --break-system-packages -r requirements.txt

COPY claude-dev/ .

# Non-root user with home dir (Claude needs ~/.claude/)
RUN useradd -m -u 1000 -s /bin/bash devagent \
    && chown -R devagent:devagent /app

USER devagent

ENTRYPOINT ["python3", "/app/orchestrator.py"]
