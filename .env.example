# ============================================================
# OpenClaw NAS Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# --- Required ---

# Claude Code OAuth token (used for Claude CLI and LLM provider auth)
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub personal access token (repo scope minimum)
GH_TOKEN=ghp_...

# --- Git identity for agent commits ---

GIT_AUTHOR_NAME=Claude Dev
GIT_AUTHOR_EMAIL=claude-dev@localhost

# --- Discord (optional, agents work without it) ---

# Each agent gets its own Discord bot token and channel.
# Leave blank to skip that agent's Discord integration.
DISCORD_FORGE_TOKEN=
DISCORD_FORGE_CHANNEL=
DISCORD_SCOUTER_TOKEN=
DISCORD_SCOUTER_CHANNEL=
DISCORD_ALFRED_TOKEN=
DISCORD_ALFRED_CHANNEL=

# Discord server (guild) ID -- required if any agent tokens are set
DISCORD_GUILD=

# --- X/Twitter API (optional, for Scouter) ---

# Bearer token for read-only X API v2 access (tweet search, lists, mentions).
# Get one at: https://developer.x.com/en/portal/dashboard
X_BEARER_TOKEN=

# Client credentials (only needed for OAuth 2.0 user-context auth, not required for read-only)
X_CLIENT_ID=
X_CLIENT_SECRET=

# --- Gateway (auto-managed) ---

# Gateway auth token. Generated on first boot if not set.
# Set explicitly to use a fixed token across rebuilds.
OPENCLAW_GATEWAY_TOKEN=

# --- Optional ---

# OpenAI Codex token (for ChatGPT subscription model access)
# Set up interactively with: make openai-codex
OPENAI_CODEX_TOKEN=
